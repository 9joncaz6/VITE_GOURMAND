{% extends 'base.html.twig' %}

{% block title %}Validation de commande{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/pages/validation.css') }}">
{% endblock %}

{% block body %}

<div class="validation-container">

    <h1 class="validation-title">Validation de votre commande</h1>

    <div class="validation-card">

        <h2 class="section-title">Votre panier</h2>

        {% for item in items %}
            {% set prixBase = item.menu.prixBase %}
            {% set nbMin = item.menu.nbPersonnesMin %}
            {% set qte = item.quantite %}
            {% set sousTotal = (prixBase / nbMin) * qte %}

            <div class="item-row">
                <div>
                    <strong>{{ item.menu.titre }}</strong><br>
                    <small>Quantité : {{ qte }}</small>
                </div>
                <div class="item-price">
                    {{ sousTotal|number_format(2, ',', ' ') }} €
                </div>
            </div>
        {% endfor %}

        <div class="divider"></div>

        <h2 class="section-title">Adresse de livraison</h2>

        <p class="address-block">
            {{ user.adressePostale }}<br>
            <a href="{{ path('app_compte_edit', { redirect: 'validation' }) }}" class="edit-link">
                Modifier mon adresse
            </a>
        </p>

        <div class="divider"></div>

        <div class="totals">
            <div class="line">
                <span>Total menus</span>
                <span>{{ totalMenus|number_format(2, ',', ' ') }} €</span>
            </div>

            <div class="line">
                <span>Frais de livraison</span>
                <span>{{ livraison|number_format(2, ',', ' ') }} €</span>
            </div>

            <div class="line total">
                <span>Total à payer</span>
                <span>{{ totalFinal|number_format(2, ',', ' ') }} €</span>
            </div>
        </div>

        <a href="{{ path('app_commande_confirmer') }}" class="btn-primary-large mt-3">
            Confirmer ma commande
        </a>

    </div>

</div>

{% endblock %}
