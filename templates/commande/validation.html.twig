{% extends 'base.html.twig' %}

{% block title %}Validation de commande{% endblock %}

{% block body %}

<h1>Validation de votre commande</h1>

<section class="validation-section">

    <h2>Votre panier</h2>

    {% for item in items %}
        {% set prixBase = item.menu.prixBase + 0 %}
        {% set nbMin = item.menu.nbPersonnesMin + 0 %}
        {% set qte = item.quantite + 0 %}
        {% set sousTotal = (prixBase / nbMin) * qte %}

        <div class="validation-item">
            <strong>{{ item.menu.titre }}</strong><br>
            Quantité : {{ qte }}<br>
            Sous-total : {{ sousTotal | number_format(2, ',', ' ') }} €
        </div>
    {% endfor %}

    <hr>

    <p>Total menus : <strong>{{ totalMenus | number_format(2, ',', ' ') }} €</strong></p>
    <p>Frais de livraison : <strong>{{ livraison | number_format(2, ',', ' ') }} €</strong></p>

    <p style="font-size:1.4rem; font-weight:bold;">
        Total à payer : {{ totalFinal | number_format(2, ',', ' ') }} €
    </p>

    <a href="{{ path('app_commande_confirmer') }}" class="btn btn-primary">
        Confirmer ma commande
    </a>

</section>

{% endblock %}
