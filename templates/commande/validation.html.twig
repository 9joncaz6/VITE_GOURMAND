{% extends 'base.html.twig' %}

{% block title %}Validation de la commande{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/pages/validation.css') }}">
{% endblock %}

{% block body %}

<div class="order-validation-container">

    <h1 class="validation-title">Validation de la commande</h1>

    <div class="recap-box">

        <h2 class="section-title">Récapitulatif</h2>

        <table class="recap-table">
            <thead>
                <tr>
                    <th>Menu</th>
                    <th>Quantité</th>
                    <th>Prix/personne</th>
                    <th>Réduction</th>
                    <th>Total menu</th>
                </tr>
            </thead>

            <tbody>
            {% for item in items %}
                {% set menu = item.menu %}
                {% set qte = item.quantite %}
                {% set prixParPersonne = menu.prixBase / menu.nbPersonnesMin %}
                {% set totalMenu = prixParPersonne * qte %}
                {% set reduction = qte >= menu.nbPersonnesMin + 5 %}

                {% if reduction %}
                    {% set totalMenu = totalMenu * 0.90 %}
                {% endif %}

                <tr>
                    <td>{{ menu.titre }}</td>
                    <td>{{ qte }}</td>
                    <td>{{ prixParPersonne|number_format(2, '.', ' ') }} €</td>
                    <td>
                        {% if reduction %}
                            <span class="badge bg-success">-10%</span>
                        {% else %}
                            —
                        {% endif %}
                    </td>
                    <td><strong>{{ totalMenu|number_format(2, '.', ' ') }} €</strong></td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="delivery-info">
            <h3>Frais de livraison</h3>

            {% if livraison is defined %}
                <p><strong>{{ livraison|number_format(2, '.', ' ') }} €</strong></p>
            {% else %}
                <p>Les frais de livraison seront calculés automatiquement lors de la confirmation.</p>
            {% endif %}
        </div>

        <div class="total-box">
            Total actuel : <strong>{{ total|number_format(2, '.', ' ') }} €</strong>
        </div>

        {% if livraison is defined %}
            <div class="total-box mt-2">
                Total avec livraison :
                <strong>{{ (total + livraison)|number_format(2, '.', ' ') }} €</strong>
            </div>
        {% endif %}

    </div>

    <div class="validation-buttons">
        <a href="{{ path('app_commande_create') }}" class="btn-primary">
            Confirmer la commande
        </a>

        <a href="{{ path('app_panier_show') }}" class="btn-secondary">
            Retour au panier
        </a>
    </div>

</div>

{% endblock %}
