{% extends 'base.html.twig' %}

{% block title %}Validation de commande{% endblock %}

{% block body %}

<h1 class="mb-4">Validation de votre commande</h1>

<div class="card">

    <table class="table">
        <thead>
            <tr>
                <th>Menu</th>
                <th>Quantité</th>
                <th>Sous-total</th>
            </tr>
        </thead>

        <tbody>
            {% for item in items %}
                <tr>
                    <td>{{ item.menu.titre }}</td>
                    <td>{{ item.quantite }}</td>
                    <td>{{ item.subtotal }} €</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <h3 class="mt-3">Total : {{ total }} €</h3>

    <a href="{{ path('app_commande_create') }}" class="btn-primary mt-3">
        Confirmer la commande
    </a>

</div>

{% endblock %}