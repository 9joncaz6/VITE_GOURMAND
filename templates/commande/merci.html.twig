{% extends 'base.html.twig' %}

{% block title %}Merci pour votre commande{% endblock %}

{% block styles %}
    <link rel="stylesheet" href="{{ asset('styles/pages/merci.css') }}">
{% endblock %}

{% block body %}

<section class="merci-container">

    <div class="merci-card">
        <div class="icon">✔</div>

        <h1>Merci pour votre commande</h1>

        <p>
            Votre commande a bien été enregistrée.<br>
            Vous recevrez un email de confirmation dans quelques instants.
        </p>

        <a href="{{ path('app_home') }}" class="btn-primary retour-btn">
            Retour à l’accueil
        </a>
    </div>

</section>

{% endblock %}