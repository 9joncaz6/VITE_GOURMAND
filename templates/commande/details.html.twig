{% extends 'base.html.twig' %}

{% block title %}Détails de la commande #{{ commande.id }}{% endblock %}

{% block body %}

<h1 class="mb-4">Détails de la commande #{{ commande.id }}</h1>

<div class="card p-4 shadow-sm">

    <h3 class="mb-3">Informations générales</h3>

    <p><strong>Date :</strong> {{ commande.createdAt|date('d/m/Y H:i') }}</p>

    <p>
        <strong>Statut :</strong>
        {% if commande.commandeStatuts|length > 0 %}
            {% set last = commande.commandeStatuts|last %}
            <span class="badge bg-primary">{{ last.statut }}</span>
        {% else %}
            <span class="badge bg-secondary">En attente</span>
        {% endif %}
    </p>

    <p><strong>Adresse de livraison :</strong> {{ commande.adresseLivraison }}</p>

    <hr>

    <h3 class="mb-3">Menus commandés</h3>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Menu</th>
                <th>Quantité</th>
                <th>Prix/personne</th>
                <th>Réduction</th>
                <th>Total menu</th>
            </tr>
        </thead>

        <tbody>
        {% for item in commande.items %}
            {% set menu = item.menu %}
            {% set qte = item.quantite %}

            {% set prixParPersonne = menu.prixBase / menu.nbPersonnesMin %}
            {% set totalMenu = prixParPersonne * qte %}
            {% set reduction = qte >= menu.nbPersonnesMin + 5 %}

            {% if reduction %}
                {% set totalMenu = totalMenu * 0.90 %}
            {% endif %}

            <tr>
                <td>{{ menu.titre }}</td>
                <td>{{ qte }}</td>
                <td>{{ prixParPersonne|number_format(2, '.', ' ') }} €</td>
                <td>
                    {% if reduction %}
                        <span class="badge bg-success">-10%</span>
                    {% else %}
                        —
                    {% endif %}
                </td>
                <td><strong>{{ totalMenu|number_format(2, '.', ' ') }} €</strong></td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <hr>

    <h3 class="mb-3">Résumé</h3>

    <p><strong>Total menus :</strong> {{ commande.total|number_format(2, '.', ' ') }} €</p>

    <p><strong>Frais de livraison :</strong>
        {{ commande.fraisLivraison|number_format(2, '.', ' ') }} €
    </p>

    <p class="mt-3 fs-5">
        <strong>Total final :</strong>
        {{ (commande.total + commande.fraisLivraison)|number_format(2, '.', ' ') }} €
    </p>

</div>

<a href="{{ path('app_compte_historique') }}" class="btn btn-secondary mt-3">
    Retour à l’historique
</a>

{% endblock %}
