{% extends 'base.html.twig' %}

{% block title %}Commande confirmée{% endblock %}

{% block body %}

<h1 class="mb-4 text-center">Merci pour votre commande ! 🎉</h1>

<div class="card p-4 shadow-sm mx-auto" style="max-width: 700px;">

    <h3 class="mb-3">Détails de la commande</h3>

    <p><strong>Numéro :</strong> #{{ commande.getId() }}</p>
    <p><strong>Date :</strong> {{ commande.createdAt|date('d/m/Y H:i') }}</p>

    <p><strong>Adresse de livraison :</strong><br>
        {{ commande.utilisateur.adressePostale }}
    </p>

    <hr>

    <h4>Menus commandés</h4>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Menu</th>
                <th>Quantité</th>
                <th>Prix unitaire</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>

        {% for item in commande.items %}
            <tr>
                <td>{{ item.menu.titre }}</td>
                <td>{{ item.quantite }}</td>
                <td>{{ item.prixUnitaire|number_format(2, ',', ' ') }} €</td>
                <td>{{ (item.prixUnitaire * item.quantite)|number_format(2, ',', ' ') }} €</td>
            </tr>
        {% endfor %}

        </tbody>
    </table>

    <hr>

    <p><strong>Frais de livraison :</strong>
        {{ commande.fraisLivraison|number_format(2, ',', ' ') }} €
    </p>

    <h3 class="mt-3">
        Total payé :
        <span class="text-success">
            {{ commande.total|number_format(2, ',', ' ') }} €
        </span>
    </h3>

    <div class="mt-4 d-flex gap-2">
        <a href="{{ path('app_menu_index') }}" class="btn btn-primary w-50">
            Retour aux menus
        </a>

        <a href="{{ path('compte_commandes') }}" class="btn btn-secondary w-50">
            Voir mes commandes
        </a>
    </div>

</div>

{% endblock %}
