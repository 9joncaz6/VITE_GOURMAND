{% extends 'base.html.twig' %}

{% block title %}Commande confirmée{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/pages/validation.css') }}">
{% endblock %}

{% block body %}

<div class="validation-container">

    <h1 class="validation-title">Merci pour votre commande 🎉</h1>

    <div class="validation-card">

        <h2 class="section-title">Détails de la commande</h2>

        <p><strong>Numéro :</strong> #{{ commande.id }}</p>
        <p><strong>Date :</strong> {{ commande.createdAt|date('d/m/Y H:i') }}</p>

        <div class="divider"></div>

        <h2 class="section-title">Adresse de livraison</h2>
        <p class="address-block">{{ commande.utilisateur.adressePostale }}</p>

        <div class="divider"></div>

        <h2 class="section-title">Menus commandés</h2>

        {% for item in commande.items %}
            <div class="item-row">
                <div>
                    <strong>{{ item.menu.titre }}</strong><br>
                    <small>Quantité : {{ item.quantite }}</small>
                </div>
                <div class="item-price">
                    {{ (item.prixUnitaire * item.quantite)|number_format(2, ',', ' ') }} €
                </div>
            </div>
        {% endfor %}

        <div class="divider"></div>

        <div class="totals">
            <div class="line">
                <span>Frais de livraison</span>
                <span>{{ commande.fraisLivraison|number_format(2, ',', ' ') }} €</span>
            </div>

            <div class="line total">
                <span>Total payé</span>
                <span>{{ commande.total|number_format(2, ',', ' ') }} €</span>
            </div>
        </div>

        <a href="{{ path('app_menu_index') }}" class="btn-primary-large mt-3">
            Retour aux menus
        </a>

        <a href="{{ path('app_compte_historique') }}" class="btn-secondary mt-2">
            Voir mes commandes
        </a>

    </div>

</div>

{% endblock %}
