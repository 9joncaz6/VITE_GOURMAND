{% extends 'base.html.twig' %}

{% block title %}Commander{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/pages/commander.css') }}">
{% endblock %}

{% block body %}

<div class="commander-container">

    <h1 class="commander-title">Commander un menu</h1>
    <p class="commander-subtitle">Choisissez votre menu et commandez en quelques clics.</p>

    <div class="menu-grid">

        {% for menu in menus %}

            <div class="menu-card {% if menu.stockDisponible <= 0 %}menu-out{% endif %}">

                <h3 class="menu-title">{{ menu.titre }}</h3>

                <p class="menu-description">{{ menu.description }}</p>

                {% set prixBase = menu.prixBase %}
                {% set min = menu.nbPersonnesMin %}
                {% set prixParPersonne = prixBase / min %}

                <div class="menu-price">
                    <span class="price-total">{{ prixBase|number_format(2, ',', ' ') }} € TTC</span>
                    <span class="price-details">
                        soit {{ prixParPersonne|number_format(2, ',', ' ') }} € / personne  
                        (min. {{ min }} pers.)
                    </span>
                </div>

                {% if menu.stockDisponible <= 0 %}

                    <span class="badge-out">Rupture de stock</span>

                    <div class="menu-actions">
                        <button class="btn-secondary disabled" disabled>Ajouter au panier</button>
                        <button class="btn-primary disabled" disabled>Commander maintenant</button>
                    </div>

                {% else %}

                    <div class="menu-actions">

                        {# 🚫 ADMIN & EMPLOYÉ BLOQUÉS #}
                        {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_EMPLOYE') %}

                            <p class="text-muted"><em>Les administrateurs ne peuvent pas commander.</em></p>

                        {% else %}

                            {# CLIENT CONNECTÉ #}
                            {% if app.user %}

                                <a href="{{ path('app_panier_add', {menuId: menu.id}) }}"
                                   class="btn-secondary">
                                    Ajouter au panier
                                </a>

                                <a href="{{ path('app_panier_add', {menuId: menu.id, redirect: 'validation'}) }}"
                                   class="btn-primary">
                                    Commander maintenant
                                </a>

                            {% else %}

                                {# VISITEUR NON CONNECTÉ #}
                                <a href="{{ path('app_login') }}" class="btn-secondary">
                                    Ajouter au panier
                                </a>

                                <a href="{{ path('app_login') }}" class="btn-primary">
                                    Commander maintenant
                                </a>

                            {% endif %}

                        {% endif %}

                    </div>

                {% endif %}

            </div>

        {% endfor %}

    </div>

</div>

{% endblock %}
