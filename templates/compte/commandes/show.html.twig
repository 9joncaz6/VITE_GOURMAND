{% extends 'base.html.twig' %}

{% block title %}Commande #{{ commande.id }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/pages/commande_show.css') }}">
{% endblock %}

{% block body %}

<a href="{{ path('app_compte_historique') }}" class="btn-back">← Retour</a>

<h1 class="page-title">Commande #{{ commande.id }}</h1>

<div class="commande-wrapper">

    <!-- SECTION TIMELINE -->
    <div class="commande-section">
        <h2 class="section-title">Suivi de la commande</h2>

        <div class="timeline">
            <div class="step {% if commande.statutActuel in ['en_attente','en_preparation','terminee'] %}active{% endif %}">
                <span class="dot"></span>
                <p>Commande passée</p>
            </div>

            <div class="step {% if commande.statutActuel in ['en_preparation','terminee'] %}active{% endif %}">
                <span class="dot"></span>
                <p>En préparation</p>
            </div>

            <div class="step {% if commande.statutActuel == 'terminee' %}active{% endif %}">
                <span class="dot"></span>
                <p>Terminée</p>
            </div>
        </div>
    </div>

    <!-- SECTION INFOS -->
    <div class="commande-section">
        <h2 class="section-title">Informations</h2>

        <div class="info-grid">
            <div>
                <span class="label">Date :</span>
                <span>{{ commande.createdAt|date('d/m/Y H:i') }}</span>
            </div>

            <div>
                <span class="label">Total :</span>
                <span class="total">{{ commande.total }} €</span>
            </div>

            <div>
                <span class="label">Statut :</span>
                <span class="badge statut-{{ commande.statutActuel }}">
                    {{ commande.statutActuel }}
                </span>
            </div>
        </div>
    </div>

    <!-- BOUTON ANNULER COMMANDE -->
    {% if commande.statutActuel == 'en_attente' %}
        <form method="post" action="{{ path('compte_commande_annuler', { id: commande.id }) }}">
            <button class="btn-cancel">❌ Annuler la commande</button>
        </form>
    {% endif %}

    <!-- BOUTON AVIS -->
    {% if commande.statutActuel == 'terminee' and commande.avis is null %}
        <a href="{{ path('compte_avis', { id: commande.id }) }}" class="btn-avis">
            ⭐ Laisser un avis
        </a>
    {% endif %}

    <!-- SECTION ITEMS -->
    <div class="commande-section">
        <h2 class="section-title">Menus commandés</h2>

        <table class="commande-table">
            <thead>
                <tr>
                    <th>Menu</th>
                    <th>Quantité</th>
                    <th>Prix unitaire</th>
                    <th>Total</th>
                </tr>
            </thead>

            <tbody>
                {% for item in commande.items %}
                    <tr>
                        <td>{{ item.menu.titre }}</td>
                        <td>{{ item.quantite }}</td>
                        <td>{{ item.prixUnitaire }} €</td>
                        <td>{{ item.total }} €</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- SECTION FRAIS -->
    <div class="commande-section">
        <h2 class="section-title">Frais de livraison</h2>
        <p class="frais">{{ commande.fraisLivraison }} €</p>
    </div>

</div>

{% endblock %}
