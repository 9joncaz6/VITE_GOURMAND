{% extends 'base.html.twig' %}

{% block title %}Commande #{{ commande.id }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/pages/detail.css') }}">
{% endblock %}

{% block body %}

<div class="commande-container">

    <a href="{{ path('app_compte_historique') }}" class="btn-retour">← Retour</a>

    <h1 class="commande-title">Commande #{{ commande.id }}</h1>

    <!-- SECTION INFOS -->
    <div class="commande-section">
        <h2>Informations</h2>

        <!-- TIMELINE DES STATUTS -->
        <div class="timeline">

            <div class="step {% if commande.statutActuel in ['en_attente','en_preparation','terminee'] %}active{% endif %}">
                <span class="dot"></span>
                <p>Commande passée</p>
            </div>

            <div class="step {% if commande.statutActuel in ['en_preparation','terminee'] %}active{% endif %}">
                <span class="dot"></span>
                <p>En préparation</p>
            </div>

            <div class="step {% if commande.statutActuel == 'terminee' %}active{% endif %}">
                <span class="dot"></span>
                <p>Terminée</p>
            </div>

        </div>

        <!-- GRID INFOS -->
        <div class="commande-infos-grid">
            <div>
                <span class="label">Date :</span>
                <span>{{ commande.createdAt|date('d/m/Y H:i') }}</span>
            </div>

            <div>
                <span class="label">Total :</span>
                <span class="total">{{ commande.total }} €</span>
            </div>

            <div>
                <span class="label">Statut actuel :</span>
                <span class="badge statut-{{ commande.statutActuel }}">
                    {{ commande.statutActuel }}
                </span>
            </div>
        </div>
    </div>

    <!-- BOUTON LAISSER UN AVIS -->
    {% if peutLaisserAvis %}
        <a href="{{ path('compte_avis', { id: commande.id }) }}"
           class="btn-avis">
            ⭐ Laisser un avis
        </a>
    {% endif %}

    <!-- SECTION ITEMS -->
    <div class="commande-section">
        <h2>Menus commandés</h2>

        <table class="commande-table">
            <thead>
                <tr>
                    <th>Menu</th>
                    <th>Quantité</th>
                    <th>Prix unitaire</th>
                    <th>Total</th>
                </tr>
            </thead>

            <tbody>
                {% for item in commande.items %}
                    <tr>
                        <td>{{ item.menu.titre }}</td>
                        <td>{{ item.quantite }}</td>
                        <td>{{ item.prixUnitaire }} €</td>
                        <td>{{ item.total }} €</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- SECTION FRAIS -->
    <div class="commande-section">
        <h2>Frais de livraison</h2>
        <p class="frais">{{ commande.fraisLivraison }} €</p>
    </div>

</div>

{% endblock %}
