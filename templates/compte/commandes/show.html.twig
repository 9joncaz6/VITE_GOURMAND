{% extends 'base.html.twig' %}

{% block title %}Commande #{{ commande.id }}{% endblock %}

{% block body %}

<h1 class="page-title">Commande #{{ commande.id }}</h1>

<a href="{{ path('compte_commandes') }}" class="btn btn-secondary mb-3">← Retour</a>

<div class="card p-4 shadow-sm">

    <h3 class="mb-3">Informations</h3>

    <p><strong>Date :</strong> {{ commande.createdAt|date('d/m/Y H:i') }}</p>
    <p><strong>Total :</strong> {{ commande.total|number_format(2, '.', ' ') }} €</p>

    <p>
        <strong>Statut actuel :</strong>
        <span class="badge badge-{{ commande.statutActuel|lower|replace({' ': '-'}) }}">
            {{ commande.statutActuel }}
        </span>
    </p>

    <hr>

    <h4>Menus commandés</h4>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Menu</th>
                <th>Quantité</th>
                <th>Prix unitaire</th>
                <th>Total</th>
            </tr>
        </thead>

        <tbody>
        {% for item in commande.items %}
            <tr>
                <td>{{ item.menu.titre }}</td>
                <td>{{ item.quantite }}</td>
                <td>{{ item.prixUnitaire|number_format(2, '.', ' ') }} €</td>
                <td>{{ (item.prixUnitaire * item.quantite)|number_format(2, '.', ' ') }} €</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <hr>

    {% if commande.fraisLivraison is defined %}
        <p><strong>Frais de livraison :</strong>
            {{ commande.fraisLivraison|number_format(2, '.', ' ') }} €
        </p>
    {% endif %}

</div>

{# 🔥 BOUTON LAISSER UN AVIS #}
{% if commande.statutActuel == 'terminée' and commande.avis is null %}
    <div class="mt-4">
        <a href="{{ path('compte_avis', { id: commande.id }) }}" class="btn btn-primary w-100">
            Laisser un avis
        </a>
    </div>
{% endif %}

{# 🔥 BOUTON MODIFIER AVIS #}
{% if commande.avis is not null %}
    <div class="mt-4">
        <a href="{{ path('compte_avis_modifier', { id: commande.avis.id }) }}" class="btn btn-warning w-100">
            Modifier mon avis
        </a>
    </div>
{% endif %}

{% endblock %}
