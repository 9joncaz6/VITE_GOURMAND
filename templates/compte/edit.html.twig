{% extends 'base.html.twig' %}

{% block title %}Modifier mes informations{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/pages/compte.css') }}">
{% endblock %}

{% block body %}

<h1 class="page-title">Modifier mes informations</h1>

<div class="account-container">

    <div class="card account-card">

        {{ form_start(form) }}

        <div class="form-grid">

            <div>
                {{ form_label(form.prenom) }}
                {{ form_widget(form.prenom, {'attr': {'class': 'form-control'}}) }}
            </div>

            <div>
                {{ form_label(form.nom) }}
                {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
            </div>

            <div class="full">
                {{ form_label(form.email) }}
                {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
            </div>

            <div class="full">
                {{ form_label(form.gsm) }}
                {{ form_widget(form.gsm, {'attr': {'class': 'form-control'}}) }}
            </div>

            <div class="full">
                {{ form_label(form.adressePostale) }}
                {{ form_widget(form.adressePostale, {'attr': {'class': 'form-control'}}) }}
            </div>

        </div>

        <button class="btn-primary-large">Enregistrer</button>

        {{ form_end(form) }}

    </div>

    <a href="{{ path('app_compte_index') }}" class="btn-back">← Retour</a>

</div>

{% endblock %}
