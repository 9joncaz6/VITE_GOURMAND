{% extends 'base.html.twig' %}

{% block title %}Historique de mes commandes{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/compte.css') }}">
{% endblock %}

{% block body %}

<h1 class="page-title">Historique de mes commandes</h1>

<div class="account-wrapper">

    {% if commandes is empty %}
        <p>Aucune commande pour le moment.</p>
    {% else %}

        <div class="order-history">

            {% for commande in commandes %}
                <div class="order-item">
                    <strong>Commande #{{ commande.id }}</strong>
                    <span>Date : {{ commande.createdAt|date('d/m/Y H:i') }}</span><br>
                    <span>Total : {{ commande.total }} €</span><br>
                    <span>Statut : {{ commande.statut }}</span><br>

                    <a href="{{ path('app_commande_show', {id: commande.id}) }}" class="btn btn-outline-primary mt-2 w-100">
                        Voir la commande
                    </a>
                </div>
            {% endfor %}

        </div>

    {% endif %}

    <a href="{{ path('app_compte_index') }}" class="btn btn-link mt-3">← Retour</a>

</div>

{% endblock %}
