{% extends 'base.html.twig' %}

{% block title %}Changer mon mot de passe{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/pages/compte.css') }}">
{% endblock %}

{% block body %}

<h1 class="page-title">Changer mon mot de passe</h1>

<div class="account-container">

    <div class="account-card">

        <h2 class="section-title">Sécurité du compte</h2>

        {{ form_start(form) }}

        <div class="form-grid">
            <div class="full">
                {{ form_label(form.plainPassword) }}
                {{ form_widget(form.plainPassword, {'attr': {'class': 'form-control'}}) }}
            </div>
        </div>

        <button class="btn-primary-large">Mettre à jour</button>

        {{ form_end(form) }}

    </div>

    <a href="{{ path('app_compte_index') }}" class="btn-back">← Retour</a>

</div>

{% endblock %}
