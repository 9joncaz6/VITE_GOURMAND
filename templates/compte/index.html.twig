{% extends 'base.html.twig' %}

{% block title %}Mon compte{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/pages/compte.css') }}">
{% endblock %}

{% block body %}

<div class="compte-container">

    <h1 class="compte-title">Mon compte</h1>

    <p class="compte-subtitle">
        Bienvenue {{ app.user.prenom }} {{ app.user.nom }}  
        <br>
        <small class="text-muted">Gérez vos informations, commandes et avis.</small>
    </p>

    <div class="compte-grid">

        <!-- Informations personnelles -->
        <a href="{{ path('app_compte_edit') }}" class="compte-card">
            <div class="compte-card-icon">👤</div>
            <h3>Mes informations</h3>
            <p>Modifier mon nom, prénom, email, adresse…</p>
        </a>

        <!-- Mot de passe -->
        <a href="{{ path('app_compte_password') }}" class="compte-card">
            <div class="compte-card-icon">🔒</div>
            <h3>Mot de passe</h3>
            <p>Changer mon mot de passe en toute sécurité.</p>
        </a>

        <!-- Historique des commandes -->
        <a href="{{ path('app_compte_historique') }}" class="compte-card">
            <div class="compte-card-icon">🧾</div>
            <h3>Mes commandes</h3>
            <p>Consulter l’historique de mes commandes.</p>
        </a>


        <!-- Supprimer mon compte -->
        <a href="{{ path('app_compte_supprimer') }}"
           class="compte-card delete-card"
           onclick="return confirm('Voulez-vous vraiment supprimer votre compte ? Cette action est irréversible.')">
            <div class="compte-card-icon">🗑️</div>
            <h3>Supprimer mon compte</h3>
            <p>Effacer définitivement mon compte et mes données.</p>
        </a>

        <!-- Déconnexion -->
        <a href="{{ path('app_logout') }}" class="compte-card logout-card">
            <div class="compte-card-icon">🚪</div>
            <h3>Déconnexion</h3>
            <p>Se déconnecter de mon compte.</p>
        </a>

    </div>

</div>

{% endblock %}
