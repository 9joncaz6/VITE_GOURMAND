{% extends 'base.html.twig' %}

{% block title %}Mon compte{% endblock %}

{% block body %}

<h1 class="mb-4">Mon compte</h1>

<div class="card p-4 shadow-sm">

    <h3 class="mb-3">Mes informations</h3>

    <p><strong>Nom :</strong> {{ app.user.nom }}</p>
    <p><strong>Prénom :</strong> {{ app.user.prenom }}</p>
    <p><strong>Email :</strong> {{ app.user.email }}</p>
    <p><strong>Téléphone :</strong> {{ app.user.gsm ?: 'Non renseigné' }}</p>
    <p><strong>Adresse :</strong> {{ app.user.adressePostale ?: 'Non renseignée' }}</p>

    <div class="mt-4 d-flex flex-column gap-2">

        <a href="{{ path('app_compte_edit') }}" class="btn btn-primary">
            Modifier mes informations
        </a>

        <a href="{{ path('app_compte_password') }}" class="btn btn-secondary">
            Changer mon mot de passe
        </a>

        <a href="{{ path('app_compte_historique') }}" class="btn btn-outline-primary">
            Historique de mes commandes
        </a>

    </div>

</div>

{% endblock %}
