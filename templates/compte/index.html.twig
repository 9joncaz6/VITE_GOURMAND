{% extends 'base.html.twig' %}

{% block title %}Mon compte{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/pages/compte.css') }}">
{% endblock %}

{% block body %}

<div class="compte-container">

    <h1 class="compte-title">Mon compte</h1>

    <p class="compte-subtitle">
        Bienvenue {{ app.user.prenom }} {{ app.user.nom }}  
        <br>
        <small class="text-muted">Gérez vos informations, avis et commandes.</small>
    </p>

    <div class="compte-grid">

        <!-- Informations personnelles -->
        <a href="{{ path('app_compte_edit') }}" class="compte-card">
            <div class="compte-card-icon">👤</div>
            <h3>Mes informations</h3>
            <p>Modifier mon nom, prénom, email, adresse…</p>
        </a>

        <!-- Mot de passe -->
        <a href="{{ path('app_compte_password') }}" class="compte-card">
            <div class="compte-card-icon">🔒</div>
            <h3>Mot de passe</h3>
            <p>Changer mon mot de passe en toute sécurité.</p>
        </a>

        <!-- Historique des commandes -->
        <a href="{{ path('app_compte_historique') }}" class="compte-card">
            <div class="compte-card-icon">🧾</div>
            <h3>Mes commandes</h3>
            <p>Consulter l’historique de mes commandes.</p>
        </a>

        <a href="{{ path('app_compte_avis') }}" class="compte-card">
            <div class="compte-card-icon">⭐</div>
            <h3>Mes avis</h3>
            <p>Consulter, modifier ou supprimer mes avis.</p>
        </a>


        <!-- Supprimer mon compte -->
        <a href="#" class="compte-card delete-card" id="openDeleteModal">
            <div class="compte-card-icon">🗑️</div>
            <h3>Supprimer mon compte</h3>
            <p>Effacer définitivement mon compte et mes données.</p>
        </a>

        <!-- Déconnexion -->
        <a href="{{ path('app_logout') }}" class="compte-card logout-card">
            <div class="compte-card-icon">🚪</div>
            <h3>Déconnexion</h3>
            <p>Se déconnecter de mon compte.</p>
        </a>

    </div>

</div>


{# ============================
   MODALE SUPPRESSION COMPTE
   ============================ #}

<div id="deleteModal" class="modal-overlay">
    <div class="modal-box">
        <h2>Supprimer mon compte</h2>
        <p>Cette action est <strong>définitive</strong> et supprimera toutes vos données.</p>

        <div class="modal-actions">
            <a href="{{ path('app_compte_supprimer') }}" class="btn-danger">Oui, supprimer</a>
            <button id="closeDeleteModal" class="btn-secondary">Annuler</button>
        </div>
    </div>
</div>


<script>
document.getElementById('openDeleteModal').addEventListener('click', function(e) {
    e.preventDefault();
    document.getElementById('deleteModal').classList.add('active');
});

document.getElementById('closeDeleteModal').addEventListener('click', function() {
    document.getElementById('deleteModal').classList.remove('active');
});
</script>

{% endblock %}
