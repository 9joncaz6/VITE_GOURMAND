{% extends 'base.html.twig' %}

{% block title %}Mon compte{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/compte.css') }}">
{% endblock %}


{% block body %}

<h1 class="page-title mb-4">Mon compte</h1>

<div class="account-wrapper">

    <div class="card p-4 shadow-sm profile-card">

        <h2 class="section-title">Mes informations</h2>

        <div class="info-grid">

            <div class="info-item">
                <span class="label">Nom :</span>
                <span class="value">{{ app.user.nom }}</span>
            </div>

            <div class="info-item">
                <span class="label">Prénom :</span>
                <span class="value">{{ app.user.prenom }}</span>
            </div>

            <div class="info-item">
                <span class="label">Email :</span>
                <span class="value">{{ app.user.email }}</span>
            </div>

            <div class="info-item">
                <span class="label">Téléphone :</span>
                <span class="value">{{ app.user.gsm }}</span>
            </div>

            <div class="info-item full">
                <span class="label">Adresse :</span>
                <span class="value">{{ app.user.adressePostale }}</span>
            </div>

        </div>

        <div class="actions">
            <a href="{{ path('app_compte_edit') }}" class="btn btn-primary w-100 mb-2">
                Modifier mes informations
            </a>

            <a href="{{ path('app_compte_password') }}" class="btn btn-outline-primary w-100 mb-2">
                Changer mon mot de passe
            </a>

            <a href="{{ path('app_compte_historique') }}" class="btn btn-outline-secondary w-100">
                Historique de mes commandes
            </a>
        </div>

    </div>

</div>



{% endblock %}
