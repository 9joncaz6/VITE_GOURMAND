{% extends 'employe/employe_base.html.twig' %}

{% block title %}Commande #{{ commande.id }}{% endblock %}

{% block employe_body %}

<h1 class="page-title">Commande #{{ commande.id }}</h1>

<div class="employe-card">

    <h3>Client</h3>
    <p>
        {{ commande.utilisateur.prenom }} {{ commande.utilisateur.nom }}<br>
        {{ commande.utilisateur.email }}<br>
        {{ commande.utilisateur.adressePostale }}
    </p>

    <hr>

    <h3>Menus commandés</h3>

    <table class="clean-table">
        <thead>
            <tr>
                <th>Menu</th>
                <th>Quantité</th>
                <th>Prix unitaire</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
        {% for item in commande.items %}
            <tr>
                <td>{{ item.menu.titre }}</td>
                <td>{{ item.quantite }}</td>
                <td>{{ item.prixUnitaire|number_format(2, '.', ' ') }} €</td>
                <td>{{ (item.prixUnitaire * item.quantite)|number_format(2, '.', ' ') }} €</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <hr>

    <h3>Historique des statuts</h3>

    <ul>
        {% for s in commande.commandeStatuts %}
            <li>
                <strong>{{ s.statut }}</strong>
                — {{ s.dateMaj|date('d/m/Y H:i') }}
                {% if s.commentaire %}
                    <br><small class="text-muted">{{ s.commentaire }}</small>
                {% endif %}
            </li>
        {% endfor %}
    </ul>

    <hr>

    {% set statutActuel = commande.statutActuel %}

    <h3>Changer le statut</h3>

    {% if statutActuel == 'annulee' %}
        <p class="text-muted"><em>Cette commande est annulée. Aucun changement de statut possible.</em></p>

    {% else %}

        <form method="post" action="{{ path('employe_commandes_statut', {id: commande.id}) }}">
            <div class="mb-3">
                <label class="form-label">Nouveau statut</label>
                <select name="statut" class="form-select" required>
                    <option value="">Choisir…</option>
                    <option value="en_preparation">En préparation</option>
                    <option value="en_livraison">En livraison</option>
                    <option value="terminee">Terminée</option>
                    <option value="annulee">Annulée</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Commentaire (optionnel)</label>
                <textarea name="commentaire" class="form-control"></textarea>
            </div>

            <button class="btn btn-success">Mettre à jour</button>
        </form>

        <hr>

        {% if statutActuel in ['en_attente', 'en_preparation'] %}
            <button class="btn btn-danger" onclick="openCancelModal()">
                Annuler la commande
            </button>
        {% endif %}

    {% endif %}

</div>

<a href="{{ path('employe_commandes_index') }}" class="btn-secondary">← Retour</a>

{# ----------------------------- MODALE D’ANNULATION ----------------------------- #}

<div id="cancelModal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <h3>Confirmer l’annulation</h3>
        <p>Voulez-vous vraiment annuler cette commande ?</p>

        <div class="modal-actions">
            <button class="btn-secondary" onclick="closeCancelModal()">Annuler</button>

            <form method="post" action="{{ path('employe_commandes_annuler', {id: commande.id}) }}">
                <button class="btn-danger">Confirmer</button>
            </form>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
function openCancelModal() {
    document.getElementById('cancelModal').style.display = 'flex';
}

function closeCancelModal() {
    document.getElementById('cancelModal').style.display = 'none';
}
</script>
{% endblock %}
