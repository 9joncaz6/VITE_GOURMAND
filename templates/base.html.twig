{# templates/base.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}V & G - Vite et Gourmand{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    {# Reset + base minimaliste #}
    <style>
        :root {
            --bg: #f5f5f5;
            --white: #ffffff;
            --text: #222222;
            --muted: #666666;
            --primary: #ff7a1a;
            --primary-dark: #e06610;
            --border: #e0e0e0;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: var(--bg);
            color: var(--text);
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        .page {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        header {
            background: var(--white);
            border-bottom: 1px solid var(--border);
        }

        .header-inner {
            max-width: 1100px;
            margin: 0 auto;
            padding: 1rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .brand {
            font-weight: 700;
            font-size: 1.4rem;
        }

        nav {
            display: flex;
            gap: 1.5rem;
            font-size: 0.95rem;
        }

        nav a {
            position: relative;
            padding-bottom: 0.2rem;
        }

        nav a.active::after {
            content: "";
            position: absolute;
            left: 0;
            bottom: 0;
            width: 100%;
            height: 2px;
            background: var(--primary);
            border-radius: 999px;
        }

        main {
            flex: 1;
            max-width: 1100px;
            margin: 0 auto;
            padding: 2rem 1.5rem 3rem;
        }

        footer {
            border-top: 1px solid var(--border);
            background: #eeeeee;
        }

        .footer-inner {
            max-width: 1100px;
            margin: 0 auto;
            padding: 1rem 1.5rem;
            font-size: 0.85rem;
            color: var(--muted);
            display: flex;
            justify-content: center;
            gap: 1.5rem;
            flex-wrap: wrap;
        }

        .btn-primary {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0.7rem 1.4rem;
            border-radius: 999px;
            border: none;
            background: var(--primary);
            color: #fff;
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
            transition: background 0.15s ease-out, transform 0.1s ease-out;
        }

        .btn-primary:hover {
            background: var(--primary-dark);
            transform: translateY(-1px);
        }

        .btn-secondary {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0.6rem 1.2rem;
            border-radius: 999px;
            border: 1px solid var(--border);
            background: var(--white);
            color: var(--text);
            font-size: 0.9rem;
            cursor: pointer;
        }

        /* Bouton utilisateur rond */
        .user-menu {
            display: flex;
            align-items: center;
        }

        .user-btn {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: var(--white);
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: background 0.15s ease-out, transform 0.1s ease-out;
        }

        .user-btn:hover {
            background: var(--bg);
            transform: translateY(-1px);
        }

        .user-icon {
            font-size: 1.2rem;
            color: var(--text);
        }

        @media (max-width: 768px) {
            .header-inner {
                padding: 0.8rem 1rem;
            }

            nav {
                display: none; /* version mobile : menu burger dans les mockups */
            }

            .brand {
                font-size: 1.2rem;
            }

            main {
                padding: 1.5rem 1rem 2.5rem;
            }
        }
    </style>

    {% block styles %}{% endblock %}
</head>

<body>
<div class="page">

    <header>
        <div class="header-inner">

            <div class="brand">V &amp; G</div>

            {# Navigation principale #}
            <nav>
                <a href="{{ path('app_home') }}"
                   class="{% if app.current_route is defined and app.current_route starts with 'app_home' %}active{% endif %}">
                    Accueil
                </a>

                <a href="{{ path('app_menu_index') }}"
                   class="{% if app.current_route is defined and app.current_route starts with 'app_menu_' %}active{% endif %}">
                    Menus
                </a>

                <a href="{{ path('app_contact') }}"
                   class="{% if app.current_route is defined and app.current_route starts with 'app_contact' %}active{% endif %}">
                    Contacts
                </a>
            </nav>

            {# Bouton compte utilisateur #}
            <div class="user-menu">
                {% if app.user %}
                    <a href="{{ path('app_compte') }}" class="user-btn">
                        <span class="user-icon">👤</span>
                    </a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="user-btn">
                        <span class="user-icon">👤</span>
                    </a>
                {% endif %}
            </div>

        </div>
    </header>

    <main>
        {% block body %}{% endblock %}
    </main>

    <footer>
        <div class="footer-inner">
            <a href="{{ path('app_horaires') }}">Horaires</a>
            <a href="{{ path('app_mentions_legales') }}">Mentions légales</a>
            <a href="{{ path('app_contact') }}">Contact</a>
        </div>
    </footer>

</div>

    {% block javascripts %}
    <script src="{{ asset('js/main.js') }}"></script>
    {% endblock %}

</body>
</html>