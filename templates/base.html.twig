{# templates/base.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}V & G - Vite et Gourmand{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link rel="stylesheet" href="{{ asset('css/app.css') }}">
    {% block styles %}{% endblock %}
</head>

<body>
<div class="page">

    {# ============================
       HEADER
       ============================ #}
    <header>
        <div class="header-inner">

            <div class="left">
                <div class="brand">V &amp; G</div>
            </div>

            <div class="right">

                <nav>
                    <a href="{{ path('app_home') }}" class="{{ app.current_route starts with 'app_home' ? 'active' }}">Accueil</a>
                    <a href="{{ path('app_menu_index') }}" class="{{ app.current_route starts with 'app_menu_' ? 'active' }}">Menus</a>
                    <a href="{{ path('app_contact') }}" class="{{ app.current_route starts with 'app_contact' ? 'active' }}">Contacts</a>
                </nav>

                <div class="user-menu">

                    {% if app.user %}
                        <div class="user-connected">
                            <a href="{{ path('app_compte') }}" class="user-avatar">
                                <span>👤</span>
                            </a>

                            <span class="user-name">{{ app.user.prenom }}</span>

                            <a href="{{ path('app_logout') }}" class="logout-link">Déconnexion</a>
                        </div>

                    {% else %}
                        <div class="user-disconnected">
                            <a href="{{ path('app_login') }}" class="login-link">Connexion</a>
                            <a href="{{ path('app_register') }}" class="register-link">Créer un compte</a>
                        </div>
                    {% endif %}

                </div>

            </div>

        </div>
    </header>

    {# ============================
       FLASH MESSAGES
       ============================ #}
    <main>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash flash-{{ label }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}
    </main>

    {# ============================
       FOOTER
       ============================ #}
    <footer>
        <div class="footer-inner">
            <a href="{{ path('app_horaires') }}">Horaires</a>
            <a href="{{ path('app_mentions_legales') }}">Mentions légales</a>
            <a href="{{ path('app_contact') }}">Contact</a>
        </div>
    </footer>

</div>

{% block javascripts %}
<script src="{{ asset('js/main.js') }}"></script>
{% endblock %}

</body>
</html>