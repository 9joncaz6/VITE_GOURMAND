<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">

    <title>{% block title %}V & G - Vite et Gourmand{% endblock %}</title>

    <meta name="description" content="V & G - Traiteur artisanal, menus variés, livraison rapide, cuisine maison et service premium.">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link rel="icon" href="{{ asset('favicon.ico') }}">

    <link rel="stylesheet" href="{{ asset('css/home.css') }}?v=1">
    <link rel="stylesheet" href="{{ asset('css/app.css') }}?v=1">
    <link rel="stylesheet" href="{{ asset('css/auth.css') }}?v=1">

    {% block stylesheets %}{% endblock %}
</head>

<body>

<div class="page">

    {# ============================
       HEADER
       ============================ #}
    <header class="header-desktop">
        <div class="header-inner">

            <div class="logo">
                <span class="logo-text">V & G</span>
            </div>

            <div class="right-side">
                <nav class="main-nav">
                    <a href="{{ path('app_home') }}">Accueil</a>
                    <a href="{{ path('app_menu_index') }}">Menus</a>

                    {# ❌ Contact masqué pour admin & employé #}
                    {% if not is_granted('ROLE_ADMIN') and not is_granted('ROLE_EMPLOYE') %}
                        <a href="{{ path('app_contact') }}">Contacts</a>
                    {% endif %}
                </nav>

                {# ❌ Panier masqué pour admin & employé #}
                {% if is_granted('ROLE_USER') 
                    and not is_granted('ROLE_ADMIN') 
                    and not is_granted('ROLE_EMPLOYE') %}
                    <a href="{{ path('app_panier_show') }}" class="cart-icon">🛒</a>
                {% endif %}

                <div class="user-menu">
                    {% if app.user %}
                        <span class="user-name">{{ app.user.prenom }}</span>

                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('admin_dashboard') }}" class="admin-link">Dashboard admin</a>
                        {% endif %}

                        {% if is_granted('ROLE_EMPLOYE') and not is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('employe_commandes_index') }}" class="admin-link">Commandes employé</a>
                        {% endif %}

                        {% if is_granted('ROLE_USER') 
                            and not is_granted('ROLE_EMPLOYE') 
                            and not is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_compte_index') }}">Mon compte</a>
                        {% endif %}

                        <a href="{{ path('app_logout') }}" class="logout-btn">Déconnexion</a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="user-icon">👤</a>
                    {% endif %}
                </div>

            </div>
        </div>
    </header>

    {# ============================
       MENU MOBILE
       ============================ #}
    <nav class="mobile-menu">
        <a href="{{ path('app_home') }}">Accueil</a>
        <a href="{{ path('app_menu_index') }}">Menus</a>

        {# ❌ Contact masqué pour admin & employé #}
        {% if not is_granted('ROLE_ADMIN') and not is_granted('ROLE_EMPLOYE') %}
            <a href="{{ path('app_contact') }}">Contacts</a>
        {% endif %}

        {# ❌ Panier masqué pour admin & employé #}
        {% if is_granted('ROLE_USER') 
            and not is_granted('ROLE_ADMIN') 
            and not is_granted('ROLE_EMPLOYE') %}
            <a href="{{ path('app_panier_show') }}">Panier 🛒</a>
        {% endif %}

        {% if app.user %}
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('admin_dashboard') }}">Dashboard admin</a>
            {% endif %}
            {% if is_granted('ROLE_EMPLOYE') and not is_granted('ROLE_ADMIN') %}
                <a href="{{ path('employe_commandes_index') }}">Commandes employé</a>
            {% endif %}
            {% if is_granted('ROLE_USER') 
                and not is_granted('ROLE_EMPLOYE') 
                and not is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_compte_index') }}">Mon compte</a>
            {% endif %}
            <a href="{{ path('app_logout') }}">Déconnexion</a>
        {% else %}
            <a href="{{ path('app_login') }}">Connexion</a>
        {% endif %}
    </nav>

    {# ============================
       CONTENU PRINCIPAL
       ============================ #}
    <main>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash flash-{{ label }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}
    </main>

    {# ============================
       FOOTER
       ============================ #}
    <footer>
        <div class="footer-inner">
            <a href="{{ path('app_horaires') }}">Horaires</a>
            <a href="{{ path('app_mentions_legales') }}">Mentions légales</a>

            {# ❌ Contact masqué pour admin & employé #}
            {% if not is_granted('ROLE_ADMIN') and not is_granted('ROLE_EMPLOYE') %}
                <a href="{{ path('app_contact') }}">Contact</a>
            {% endif %}
        </div>
    </footer>

</div>

{# ============================
   JAVASCRIPT
   ============================ #}
{% block javascripts %}
    <script src="{{ asset('js/main.js') }}"></script>
    <script src="{{ asset('js/menu-filters.js') }}"></script>
{% endblock %}

</body>
</html>
