{# templates/base.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}V & G - Vite et Gourmand{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    {# CSS global #}
    <link rel="stylesheet" href="{{ asset('css/app.css') }}">
    {% block styles %}{% endblock %}
</head>

<body>
<div class="page">

    {# ============================
       HEADER DESKTOP
       ============================ #}
    <header class="header-desktop">
        <div class="header-desktop__logo">V & G</div>

        <nav class="header-desktop__nav">
            <a href="{{ path('app_home') }}"
               class="{% if app.request.get('_route') == 'app_home' %}active{% endif %}">
                Accueil
            </a>

            <a href="{{ path('app_menus') }}"
               class="{% if app.request.get('_route') starts with 'app_menus' %}active{% endif %}">
                Menus
            </a>

            <a href="{{ path('app_contact') }}"
               class="{% if app.request.get('_route') == 'app_contact' %}active{% endif %}">
                Contacts
            </a>
        </nav>
    </header>


    {# ============================
       HEADER MOBILE - ACCUEIL
       ============================ #}
    <header class="header-mobile header-mobile--home">
        <div class="header-mobile__burger">三</div>
        <div class="header-mobile__logo">V & G</div>
    </header>

    {# ============================
       HEADER MOBILE - PAGES INTERNES
       (Menus, Détails, etc.)
       ============================ #}
    <header class="header-mobile header-mobile--back">
        <div class="header-mobile__back">‹</div>
        <div class="header-mobile__title">
            {% block mobile_page_title %}{% endblock %}
        </div>
    </header>


    {# ============================
       FLASH MESSAGES
       ============================ #}
    <main>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash flash-{{ label }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}
    </main>


    {# ============================
       FOOTER
       ============================ #}
    <footer>
        <div class="footer-inner">
            <a href="{{ path('app_horaires') }}">Horaires</a>
            <a href="{{ path('app_mentions_legales') }}">Mentions légales</a>
            <a href="{{ path('app_contact') }}">Contact</a>
        </div>
    </footer>

</div>

{% block javascripts %}
<script src="{{ asset('js/main.js') }}"></script>
{% endblock %}

</body>
</html>