{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<div class="auth-container">

    <h1 class="auth-title">Connexion</h1>

    {% for message in app.flashes('success') %}
        <div class="alert-success-custom">
            {{ message }}
        </div>
    {% endfor %}

    {% if error %}
        <div class="alert-error-custom">
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
    {% endif %}

    <form method="post">

        <div class="auth-field">
            <label>Email</label>
            <input type="text" name="_username" value="{{ last_username }}" required class="auth-input">
        </div>

        <div class="auth-field">
            <label>Mot de passe</label>
            <input type="password" name="_password" required class="auth-input">
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button class="btn-primary auth-btn">Se connecter</button>
    </form>

    <div class="auth-links">
        <a href="{{ path('app_forgot_password') }}">Mot de passe oublié ?</a>
        <br>
        <a href="{{ path('app_register') }}">Créer un compte</a>
    </div>

</div>
{% endblock %}
