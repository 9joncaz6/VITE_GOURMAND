{% extends 'base.html.twig' %}

{% block title %}Réinitialiser le mot de passe{% endblock %}

{% block body %}
<div class="auth-container">

    <h1 class="auth-title">Nouveau mot de passe</h1>

    <p class="auth-text">
        Choisissez un nouveau mot de passe pour votre compte.
    </p>

    {% for message in app.flashes('error') %}
        <div class="alert-error-custom">{{ message }}</div>
    {% endfor %}

    {# IMPORTANT : on ajoute l'action pour que le POST parte bien vers la bonne route #}
    <form method="post" action="{{ path('app_reset_password', { token: token }) }}">

        <div class="auth-field">
            <label class="auth-label">Nouveau mot de passe</label>
            <input type="password" name="password" required class="auth-input">
        </div>

        <button class="btn-primary auth-btn">Valider</button>
    </form>

    <div class="auth-links">
        <a href="{{ path('app_login') }}">Retour à la connexion</a>
    </div>

</div>
{% endblock %}
