{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
<div class="auth-container">

    <h1 class="auth-title">Mot de passe oublié</h1>

    <p class="auth-text">
        Entrez votre adresse email et nous vous enverrons un lien pour réinitialiser votre mot de passe.
    </p>

    {% for message in app.flashes('success') %}
        <div class="alert-success-custom">{{ message }}</div>
    {% endfor %}

    <form method="post">

        <div class="auth-field">
            <label class="auth-label">Adresse email</label>
            <input type="email" name="email" required class="auth-input">
        </div>

        <button class="btn-primary auth-btn">Envoyer le lien</button>
    </form>

    <div class="auth-links">
        <a href="{{ path('app_login') }}">Retour à la connexion</a>
    </div>

</div>
{% endblock %}
