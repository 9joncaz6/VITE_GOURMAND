<form method="post"
      action="{{ path('admin_theme_delete', { id: theme.id }) }}"
      onsubmit="return confirm('Supprimer ce thème ?');"
      class="inline-form">

    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ theme.id) }}">

    <button class="btn-danger">Supprimer</button>
</form>
