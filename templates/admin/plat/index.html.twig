{% extends 'base.html.twig' %}

{% block title %}Plats{% endblock %}

{% block body %}
<h1>Gestion des plats</h1>

<a href="{{ path('app_plat_new') }}" class="btn btn-primary mb-3">+ Ajouter un plat</a>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Nom</th>
            <th>Type</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        {% for plat in plats %}
            <tr>
                <td>{{ plat.id }}</td>
                <td>{{ plat.nom }}</td>
                <td>{{ plat.type }}</td>
                <td>
                    <a href="{{ path('app_plat_edit', {id: plat.id}) }}" class="btn btn-sm btn-warning">Modifier</a>
                    <a href="{{ path('app_plat_delete', {id: plat.id}) }}" class="btn btn-sm btn-danger"
                       onclick="return confirm('Supprimer ce plat ?')">Supprimer</a>
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}
