{% extends 'base.html.twig' %}

{% block title %}Commandes — Administration{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/employe/employe_commandes.css') }}">
{% endblock %}

{% block body %}

<h1 class="page-title">Gestion des commandes</h1>

<div class="table-wrapper">

    <div class="filters">

        <form method="get" class="filter-form">
            <select name="statut" onchange="this.form.submit()">
                <option value="">Tous les statuts</option>
                <option value="en_attente" {{ statutFiltre == 'en_attente' ? 'selected' }}>En attente</option>
                <option value="en_preparation" {{ statutFiltre == 'en_preparation' ? 'selected' }}>En préparation</option>
                <option value="terminee" {{ statutFiltre == 'terminee' ? 'selected' }}>Terminée</option>
                <option value="annulee" {{ statutFiltre == 'annulee' ? 'selected' }}>Annulée</option>
            </select>
        </form>

        <div class="counters">
            <span class="counter counter-attente">En attente : {{ countEnAttente }}</span>
            <span class="counter counter-prepa">En préparation : {{ countEnPreparation }}</span>
            <span class="counter counter-terminee">Terminées : {{ countTerminees }}</span>
            <span class="counter counter-annulee">Annulées : {{ countAnnulees }}</span>
        </div>

    </div>

    <table class="orders-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Date</th>
                <th>Total</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
        {% for commande in commandes %}
            {% set statut = commande.statutActuel %}
            <tr>
                <td>#{{ commande.id }}</td>
                <td>{{ commande.createdAt|date('d/m/Y H:i') }}</td>
                <td>{{ commande.total|number_format(2, ',', ' ') }} €</td>

                <td>
                    <span class="badge badge-{{ statut|lower|replace({' ': '-'}) }}">
                        {{ statut }}
                    </span>
                </td>

                <td>
                    <a href="{{ path('admin_commandes_show', {id: commande.id}) }}" class="btn-view">
                        Voir
                    </a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5" class="text-center text-muted">Aucune commande trouvée.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

</div>

{% endblock %}
