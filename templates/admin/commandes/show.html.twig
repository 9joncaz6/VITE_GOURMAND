{% extends 'base.html.twig' %}

{% block title %}Commande #{{ commande.getId() }} (Admin){% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/employe/employe_commandes.css') }}">
{% endblock %}

{% block body %}

<h1 class="page-title">Commande #{{ commande.getId() }} — Administration</h1>

<a href="{{ path('admin_commandes_index') }}" class="btn-back">← Retour aux commandes</a>

<div class="commande-details">

    <!-- Informations client -->
    <div class="section">
        <h2>Informations client</h2>
        <p><strong>Nom :</strong> {{ commande.utilisateur.nom }}</p>
        <p><strong>Prénom :</strong> {{ commande.utilisateur.prenom }}</p>
        <p><strong>Email :</strong> {{ commande.utilisateur.email }}</p>
        <p><strong>Adresse :</strong> {{ commande.utilisateur.adressePostale }}</p>
    </div>

    <!-- Détails commande -->
    <div class="section">
        <h2>Détails de la commande</h2>
        <p><strong>Date :</strong> {{ commande.createdAt|date('d/m/Y H:i') }}</p>
        <p><strong>Total :</strong> {{ commande.total|number_format(2, ',', ' ') }} €</p>

        {% set statut = commande.statutActuel %}
        <p>
            <strong>Statut actuel :</strong>
            <span class="badge badge-{{ statut|lower|replace({' ': '-'}) }}">
                {{ statut }}
            </span>
        </p>
    </div>

    <!-- Articles -->
    <div class="section">
        <h2>Articles</h2>
        <ul class="items-list">
            {% for item in commande.items %}
                <li>
                    <strong>{{ item.menu.titre }}</strong>
                    — {{ item.quantite }} × {{ item.prixUnitaire|number_format(2, ',', ' ') }} €
                    = <strong>{{ (item.quantite * item.prixUnitaire)|number_format(2, ',', ' ') }} €</strong>
                </li>
            {% endfor %}
        </ul>
    </div>

    <!-- Historique des statuts -->
    <div class="section">
        <h2>Historique des statuts</h2>
        <ul class="status-history">
            {% for statut in commande.commandeStatuts %}
                <li>
                    <span class="badge badge-{{ statut.statut|lower|replace({' ': '-'}) }}">
                        {{ statut.statut }}
                    </span>
                    — {{ statut.dateMaj|date('d/m/Y H:i') }}

                    {% if statut.commentaire %}
                        <br><em>{{ statut.commentaire }}</em>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    </div>

    <!-- Mise à jour du statut -->
    <div class="section">
        <h2>Mettre à jour le statut</h2>

        <form action="{{ path('admin_commandes_statut', {id: commande.getId()}) }}" method="post" class="status-form">

            <label for="statut">Nouveau statut :</label>
            <select name="statut" id="statut" required>
                <option value="">Choisir…</option>
                <option value="en_attente">En attente</option>
                <option value="en_preparation">En préparation</option>
                <option value="terminee">Terminée</option>
            </select>

            <label for="commentaire">Commentaire (optionnel) :</label>
            <textarea name="commentaire" id="commentaire" rows="3"></textarea>

            <button type="submit" class="btn-update">Mettre à jour</button>
        </form>
    </div>

</div>

{% endblock %}
