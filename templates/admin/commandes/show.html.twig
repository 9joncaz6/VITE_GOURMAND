{% extends 'admin/admin_base.html.twig' %}

{% block title %}Commande #{{ commande.id }} — Administration{% endblock %}

{% block admin_styles %}
<link rel="stylesheet" href="{{ asset('styles/admin/commande.css') }}">
{% endblock %}

{% block admin_body %}

<a href="{{ path('admin_commandes_index') }}" class="btn-retour">← Retour aux commandes</a>

<h1 class="page-title">Commande #{{ commande.id }} — Administration</h1>

<div class="commande-details">

    <!-- INFORMATIONS CLIENT -->
    <div class="commande-info">
        <h2 class="section-title">Informations client</h2>

        <p><strong>Nom :</strong> {{ commande.utilisateur.nom }}</p>
        <p><strong>Prénom :</strong> {{ commande.utilisateur.prenom }}</p>
        <p><strong>Email :</strong> {{ commande.utilisateur.email }}</p>
        <p><strong>Adresse :</strong> {{ commande.utilisateur.adressePostale }}</p>
    </div>

    <!-- MISE À JOUR DU STATUT -->
    <div class="commande-status-update">
        <h2 class="section-title">Mettre à jour le statut</h2>

        <form method="post">

            <label for="statut">Nouveau statut :</label>
            <select name="statut" id="statut">
                <option value="">Choisir...</option>
                <option value="en_attente">En attente</option>
                <option value="en_preparation">En préparation</option>
                <option value="en_livraison">En livraison</option>
                <option value="terminee">Terminée</option>
                <option value="annulee">Annulée</option>
            </select>

            <label for="commentaire">Commentaire (optionnel) :</label>
            <textarea name="commentaire" id="commentaire"></textarea>

            <button class="btn-primary">Mettre à jour</button>
        </form>

        <form method="post" action="{{ path('admin_commandes_cancel', { id: commande.id }) }}">
            <button class="btn-danger" style="margin-top: 1rem;">Annuler la commande</button>
        </form>
    </div>

</div>

<!-- DÉTAILS DE LA COMMANDE -->
<h2 class="section-title">Détails de la commande</h2>

<p><strong>Date :</strong> {{ commande.createdAt|date('d/m/Y H:i') }}</p>
<p><strong>Total :</strong> {{ commande.total|number_format(2, ',', ' ') }} €</p>

<p><strong>Statut actuel :</strong>
    <span class="badge badge-{{ commande.statutActuel|lower|replace({' ': '-'}) }}">
        {{ commande.statutActuel }}
    </span>
</p>

<!-- ARTICLES -->
<h2 class="section-title">Articles</h2>

<table class="table-commandes">
    <thead>
        <tr>
            <th>Menu</th>
            <th>Quantité</th>
            <th>Prix unitaire</th>
            <th>Total</th>
        </tr>
    </thead>

    <tbody>
        {% for item in commande.items %}
            <tr>
                <td>{{ item.menu.titre }}</td>
                <td>{{ item.quantite }}</td>
                <td>{{ item.prixUnitaire }} €</td>
                <td>{{ item.total }} €</td>
            </tr>
        {% endfor %}
    </tbody>
</table>

<!-- HISTORIQUE DES STATUTS -->
<h2 class="section-title">Historique des statuts</h2>

<ul>
    {% for statut in commande.commandeStatuts %}
        <li>
            <strong>{{ statut.statut }}</strong> — {{ statut.date|date('d/m/Y H:i') }}
            {% if statut.commentaire %}
                <br><em>{{ statut.commentaire }}</em>
            {% endif %}
        </li>
    {% endfor %}
</ul>

{% endblock %}
