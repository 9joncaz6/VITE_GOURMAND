{% extends 'base.html.twig' %}

{% block title %}Commande #{{ commande.id }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/admin/commande.css') }}">
{% endblock %}

{% block body %}

<h1 class="page-title">Commande #{{ commande.id }}</h1>

<div class="commande-details">

    <div class="commande-info">
        <p><strong>Date :</strong> {{ commande.createdAt|date('d/m/Y H:i') }}</p>

        <p>
            <strong>Statut :</strong>
            <span class="badge badge-{{ commande.statutActuel|lower|replace({' ': '-'}) }}">
                {{ commande.statutActuel }}
            </span>
        </p>

        <p><strong>Total :</strong> {{ commande.total }} €</p>
    </div>

    <div class="commande-status-update">
        <h3>Changer le statut</h3>

        <div class="status-buttons">
            <a href="{{ path('admin_commandes_status', { id: commande.id, status: 'En attente' }) }}" class="btn-secondary">En attente</a>
            <a href="{{ path('admin_commandes_status', { id: commande.id, status: 'En préparation' }) }}" class="btn-secondary">En préparation</a>
            <a href="{{ path('admin_commandes_status', { id: commande.id, status: 'En livraison' }) }}" class="btn-secondary">En livraison</a>
            <a href="{{ path('admin_commandes_status', { id: commande.id, status: 'Terminée' }) }}" class="btn-secondary">Terminée</a>
        </div>
    </div>

</div>

<h2 class="section-title">Menus commandés</h2>

<table class="table-commandes">
    <thead>
        <tr>
            <th>Menu</th>
            <th>Quantité</th>
            <th>Prix unitaire</th>
            <th>Total</th>
        </tr>
    </thead>

    <tbody>
        {% for item in commande.items %}
            <tr>
                <td>{{ item.menu.titre }}</td>
                <td>{{ item.quantite }}</td>
                <td>{{ item.prixUnitaire }} €</td>
                <td>{{ item.prixUnitaire * item.quantite }} €</td>

            </tr>
        {% endfor %}
    </tbody>
</table>

<a href="{{ path('admin_commandes_index') }}" class="btn-secondary" style="margin-top: 2rem; display: inline-block;">
    Retour
</a>

{% endblock %}
