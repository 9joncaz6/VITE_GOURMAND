{% extends 'admin/admin_base.html.twig' %}

{% block title %}Gestion des employés{% endblock %}

{% block admin_body %}

<h1 class="page-title">Gestion des employés</h1>

<a href="{{ path('admin_employes_new') }}" class="btn-success mb-3 d-inline-block">
    + Créer un employé
</a>

<div class="card shadow-sm p-0">

    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Nom complet</th>
                <th>Email</th>
                <th>Actif</th>
                <th>Rôle</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>

        <tbody>
            {% for employe in employes %}
                <tr>
                    <td class="fw-bold">{{ employe.id }}</td>

                    <td>{{ employe.prenom }} {{ employe.nom }}</td>

                    <td class="text-muted">{{ employe.email }}</td>

                    <td>
                        {% if employe.actif %}
                            <span class="badge bg-success">Actif</span>
                        {% else %}
                            <span class="badge bg-danger">Inactif</span>
                        {% endif %}
                    </td>

                    <td>
                        {% if 'ROLE_ADMIN' in employe.roles %}
                            <span class="badge bg-primary">Admin</span>
                        {% elseif 'ROLE_EMPLOYE' in employe.roles %}
                            <span class="badge bg-info text-dark">Employé</span>
                        {% else %}
                            <span class="badge bg-secondary">—</span>
                        {% endif %}
                    </td>

                    <td class="text-end">

                        <a href="{{ path('admin_employe_edit', { id: employe.id }) }}"
                           class="btn btn-sm btn-warning me-2">
                            Modifier
                        </a>

                        <form method="post"
                              action="{{ path('admin_employe_delete', { id: employe.id }) }}"
                              class="d-inline delete-form">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ employe.id) }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                Supprimer
                            </button>
                        </form>

                    </td>
                </tr>
            {% endfor %}
        </tbody>

    </table>

</div>

{% endblock %}
