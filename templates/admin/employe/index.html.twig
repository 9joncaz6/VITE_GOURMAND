{% extends 'admin/admin_base.html.twig' %}

{% block title %}Gestion des employés{% endblock %}

{% block body %}
<div class="container py-4">

    <h1 class="mb-4 fw-bold">Gestion des comptes employés</h1>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">

            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Nom complet</th>
                        <th>Email</th>
                        <th>Actif</th>
                        <th>Rôles</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    {% for employe in employes %}
                        <tr>
                            <td class="fw-bold">{{ employe.id }}</td>

                            <td>{{ employe.prenom }} {{ employe.nom }}</td>

                            <td>
                                <span class="text-muted">{{ employe.email }}</span>
                            </td>

                            <td>
                                {% if employe.actif %}
                                    <span class="badge bg-success">Actif</span>
                                {% else %}
                                    <span class="badge bg-danger">Inactif</span>
                                {% endif %}
                            </td>

                            <td>
                                {% for role in employe.roles %}
                                    {% if role == 'ROLE_ADMIN' %}
                                        <span class="badge bg-primary">Admin</span>
                                    {% elseif role == 'ROLE_EMPLOYE' %}
                                        <span class="badge bg-info text-dark">Employé</span>
                                    {% elseif role == 'ROLE_USER' %}
                                        <span class="badge bg-secondary">Utilisateur</span>
                                    {% endif %}
                                {% endfor %}
                            </td>

                            <td class="text-end">

                                <a href="{{ path('admin_employe_edit', { id: employe.id }) }}"
                                   class="btn btn-sm btn-warning me-2">
                                    Modifier
                                </a>

                                <form action="{{ path('admin_employe_delete', { id: employe.id }) }}"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('Supprimer cet employé ?');">
                                    <button class="btn btn-sm btn-outline-danger">Supprimer</button>
                                </form>

                            </td>
                        </tr>
                    {% endfor %}
                </tbody>

            </table>

        </div>
    </div>

</div>
{% endblock %}
