{% extends 'base.html.twig' %}

{% block title %}Dashboard Admin{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/admin/dashboard.css') }}">
{% endblock %}

{% block body %}

<h1 class="page-title">Dashboard Administrateur</h1>

<section class="stats">
    <div class="stat-box">
        <h3>Total commandes</h3>
        <p>{{ stats.totalCommandes }}</p>
    </div>

    <div class="stat-box">
        <h3>Total menus</h3>
        <p>{{ stats.totalMenus }}</p>
    </div>

    <div class="stat-box">
        <h3>Total utilisateurs</h3>
        <p>{{ stats.totalUsers }}</p>
    </div>

    <div class="stat-box">
        <h3>Chiffre d'affaires</h3>
        <p>{{ stats.caTotal }} €</p>
    </div>
</section>

<h2 class="section-title">Dernières commandes</h2>

<table class="table-dashboard">
    <thead>
        <tr>
            <th>ID</th>
            <th>Date</th>
            <th>Total</th>
            <th>Statut</th>
        </tr>
    </thead>
    <tbody>
        {% for c in commandes %}
            <tr>
                <td>#{{ c.id }}</td>
                <td>{{ c.createdAt|date('d/m/Y H:i') }}</td>
                <td>{{ c.total }} €</td>
                <td>
                    <span class="badge badge-{{ c.status|lower|replace({' ': '-'}) }}">
                        {{ c.status }}
                    </span>
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>

<h2 class="section-title">Derniers utilisateurs</h2>
<ul class="list-dashboard">
    {% for u in users %}
        <li>{{ u.email }}</li>
    {% endfor %}
</ul>

<h2 class="section-title">Derniers menus ajoutés</h2>
<ul class="list-dashboard">
    {% for m in menus %}
        <li>{{ m.titre }}</li>
    {% endfor %}
</ul>

{% endblock %}
