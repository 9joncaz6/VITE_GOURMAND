{% extends 'base.html.twig' %}

{% block title %}Dashboard Admin{% endblock %}

{% block body %}
<h1>Dashboard Administrateur</h1>

<section class="stats">
    <div class="stat-box">
        <h3>Total commandes</h3>
        <p>{{ stats.totalCommandes }}</p>
    </div>

    <div class="stat-box">
        <h3>Total menus</h3>
        <p>{{ stats.totalMenus }}</p>
    </div>

    <div class="stat-box">
        <h3>Total utilisateurs</h3>
        <p>{{ stats.totalUsers }}</p>
    </div>

    <div class="stat-box">
        <h3>Chiffre d'affaires</h3>
        <p>{{ stats.caTotal }} €</p>
    </div>
</section>

<hr>

<h2>Dernières commandes</h2>
<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Date</th>
            <th>Total</th>
            <th>Statut</th>
        </tr>
    </thead>
    <tbody>
        {% for c in commandes %}
            <tr>
                <td>{{ c.id }}</td>
                <td>{{ c.createdAt|date('d/m/Y H:i') }}</td>
                <td>{{ c.total }} €</td>
                <td>{{ c.status }}</td>
            </tr>
        {% endfor %}
    </tbody>
</table>

<hr>

<h2>Derniers utilisateurs</h2>
<ul>
    {% for u in users %}
        <li>{{ u.email }}</li>
    {% endfor %}
</ul>

<hr>

<h2>Derniers menus ajoutés</h2>
<ul>
    {% for m in menus %}
        <li>{{ m.titre }}</li>
    {% endfor %}
</ul>

{% endblock %}