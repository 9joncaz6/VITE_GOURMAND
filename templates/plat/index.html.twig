{% extends 'base.html.twig' %}

{% block body %}
<h1 class="mb-4">Liste des plats</h1>

<a href="{{ path('app_plat_new') }}" class="btn btn-primary mb-3">Créer un plat</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nom</th>
            <th>Type</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for plat in plats %}
            <tr>
                <td>{{ plat.nom }}</td>
                <td>{{ plat.type }}</td>
                <td>
                    <a href="{{ path('app_plat_edit', {id: plat.id}) }}" class="btn btn-warning btn-sm">Modifier</a>

                    <form method="post" action="{{ path('app_plat_delete', {id: plat.id}) }}" style="display:inline-block;">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ plat.id) }}">
                        <button class="btn btn-danger btn-sm" onclick="return confirm('Supprimer ce plat ?')">Supprimer</button>
                    </form>
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}