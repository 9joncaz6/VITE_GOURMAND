<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Confirmation de commande</title>
</head>

<body style="font-family: Arial, sans-serif; background:#f5f5f5; padding:20px; margin:0;">

<div style="background:#ffffff; padding:20px; border-radius:12px; max-width:600px; margin:auto; border:1px solid #e0e0e0;">

    <h1 style="color:#ff7a1a; font-size:1.6rem; margin-bottom:1rem;">
        Merci pour votre commande, {{ user.prenom }} !
    </h1>

    <p style="margin-bottom:0.8rem; color:#444;">
        Votre commande <strong>#{{ commande.id }}</strong> a bien été enregistrée.
    </p>

    <h2 style="margin-top:1.5rem; font-size:1.2rem; color:#333;">
        Détails de la commande :
    </h2>

    {% for item in items %}
        {% set prixBase = item.menu.prixBase + 0 %}
        {% set nbMin = item.menu.nbPersonnesMin + 0 %}
        {% set qte = item.quantite + 0 %}
        {% set sousTotal = (prixBase / nbMin) * qte %}

        <div style="margin-bottom:12px; padding-bottom:10px; border-bottom:1px solid #eee;">
            <strong>{{ item.menu.titre }}</strong><br>
            Quantité : {{ qte }}<br>
            Prix unitaire : {{ (prixBase / nbMin) | number_format(2, ',', ' ') }} €<br>
            Sous-total : {{ sousTotal | number_format(2, ',', ' ') }} €
        </div>
    {% endfor %}

    <p style="margin-top:1.5rem; font-size:1.1rem; color:#444;">
        Frais de livraison : <strong>{{ commande.fraisLivraison | number_format(2, ',', ' ') }} €</strong>
    </p>

    <p style="font-size:1.3rem; font-weight:bold; margin-top:10px; color:#222;">
        Total payé : {{ commande.total | number_format(2, ',', ' ') }} €
    </p>

    <p style="margin-top:1.5rem; color:#444;">
        Vous pouvez consulter vos commandes à tout moment dans votre espace client.
    </p>

    <p style="margin-bottom:0.8rem; color:#444;">
        À bientôt,<br>
        <strong>Vite & Gourmand</strong>
    </p>

</div>

</body>
</html>
