{% extends 'base.html.twig' %}

{% block title %}Modifier mon avis{% endblock %}

{% block body %}
<div class="container mt-5" style="max-width: 700px;">

    <h2 class="mb-4 text-center">Modifier mon avis</h2>

    <div class="card shadow-sm p-4">

        {{ form_start(form) }}

            <div class="mb-3">
                <label class="form-label fw-bold">Votre note</label>
                <div class="d-flex gap-3">
                    {{ form_widget(form.note) }}
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Votre commentaire</label>
                {{ form_widget(form.commentaire, {
                    'attr': {'class': 'form-control'}
                }) }}
            </div>

            <button class="btn btn-warning w-100 mt-3">
                Enregistrer les modifications
            </button>

        {{ form_end(form) }}

    </div>

    <div class="text-center mt-4">
        <a href="{{ path('compte_commandes') }}" class="text-decoration-none">
            ← Retour à mes commandes
        </a>
    </div>

</div>
{% endblock %}
