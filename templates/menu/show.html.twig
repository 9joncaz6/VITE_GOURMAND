{% extends 'base.html.twig' %}

{% block title %}{{ menu.titre }}{% endblock %}

{% block body %}

<h1 class="mb-4">{{ menu.titre }}</h1>

<div class="row mb-4">

    <!-- Image principale -->
    <div class="col-md-6">
        {% if menu.images is not empty %}
            <img src="{{ asset('uploads/menus/' ~ menu.images[0]) }}" class="img-fluid rounded shadow-sm">
        {% else %}
            <p class="text-muted">Aucune image disponible.</p>
        {% endif %}
    </div>

    <!-- Informations -->
    <div class="col-md-6">

        <h3>Description</h3>
        <p>{{ menu.description }}</p>

        <p><strong>Prix :</strong> {{ menu.prixBase }} €</p>
        <p><strong>Nombre minimum de personnes :</strong> {{ menu.nbPersonnesMin }}</p>
        <p><strong>Conditions :</strong> {{ menu.conditions }}</p>

        <p><strong>Thème :</strong> {{ menu.theme ? menu.theme.nom : 'Aucun' }}</p>
        <p><strong>Régime :</strong> {{ menu.regime ? menu.regime.nom : 'Aucun' }}</p>

        <!-- Bouton Ajouter au panier -->
        <a href="{{ path('app_panier_add', {menuId: menu.id}) }}" class="btn btn-success btn-lg mt-3">
            Ajouter au panier
        </a>

        <!-- Boutons admin -->
        {% if is_granted('ROLE_ADMIN') %}
            <div class="mt-3">
                <a href="{{ path('app_menu_edit', {id: menu.id}) }}" class="btn btn-warning btn-sm">Modifier</a>

                <form method="post" action="{{ path('app_menu_delete', {id: menu.id}) }}" style="display:inline-block;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ menu.id) }}">
                    <button class="btn btn-danger btn-sm" onclick="return confirm('Supprimer ce menu ?')">
                        Supprimer
                    </button>
                </form>
            </div>
        {% endif %}

    </div>
</div>

<hr>

<!-- Galerie -->
<h3>Galerie d’images</h3>
<div class="row">
    {% for img in menu.images %}
        <div class="col-3 mb-3">
            <img src="{{ asset('uploads/menus/' ~ img) }}" class="img-fluid rounded shadow-sm">
        </div>
    {% else %}
        <p class="text-muted">Aucune image disponible.</p>
    {% endfor %}
</div>

<hr>

<!-- Plats -->
<h3>Plats du menu</h3>
<ul>
    {% for plat in menu.plats %}
        <li class="mb-2">
            <strong>{{ plat.nom }}</strong> ({{ plat.type }}) — {{ plat.prix }} €
            <br>
            <small class="text-muted">
                Allergènes :
                {% for allergene in plat.allergenes %}
                    {{ allergene.nom }}{% if not loop.last %}, {% endif %}
                {% else %}
                    Aucun
                {% endfor %}
            </small>
        </li>
    {% endfor %}
</ul>

<!-- Retour -->
<a href="{{ path('app_commander') }}" class="btn btn-secondary mt-4">Retour</a>

{% endblock %}