{% extends 'base.html.twig' %}

{% block title %}{{ menu.titre }}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/pages/menu.css') }}">
{% endblock %}

{% block body %}

<div class="menu-layout">

    <!-- COLONNE GAUCHE : IMAGE -->
    <div class="menu-left">
        {% if menu.images is not empty %}
            <img src="{{ asset('uploads/menus/' ~ menu.images[0]) }}" class="menu-image">
        {% endif %}
    </div>

    <!-- COLONNE DROITE : TEXTE -->
    <div class="menu-right">

        <h1 class="menu-title">{{ menu.titre }}</h1>

        <h2 class="menu-subtitle">Description</h2>

        <p class="menu-description">{{ menu.description }}</p>

        {% if moyenne %}
            {% set full = moyenne|round(0, 'floor') %}
            {% set empty = 5 - full %}

            <p class="menu-rating">
                {% for i in 1..full %}★{% endfor %}
                {% for i in 1..empty %}☆{% endfor %}
                ({{ moyenne|number_format(1, '.', ' ') }}/5)
            </p>
        {% endif %}

        <p class="menu-price">{{ menu.prixBase }}€ TTC</p>

        {% if menu.stockDisponible > 0 %}

            <!-- AJOUTER AU PANIER -->
            <a href="{{ path('app_panier_add', { menuId: menu.id }) }}"
               class="menu-button">
                Ajouter au panier
            </a>

            <!-- COMMANDER = ajouter + aller au panier -->
            {% if app.user and app.user.adressePostale %}
                <a href="{{ path('app_panier_add', { menuId: menu.id, redirect: 'panier' }) }}"
                   class="commander-btn w-100 mt-3">
                    Commander
                </a>
            {% else %}
                <a href="{{ path('app_profil_edit') }}"
                   class="commander-btn w-100 mt-3">
                    Commander
                </a>
            {% endif %}

        {% else %}
            <span class="badge bg-danger mt-2">Stock épuisé</span>
        {% endif %}

    </div>

</div>

<hr>

<h3>Allergènes du menu</h3>
{% if allergenesMenu is not empty %}
    <div class="allergenes">
        {% for allergene in allergenesMenu %}
            <span class="badge bg-danger">{{ allergene }}</span>
        {% endfor %}
    </div>
{% else %}
    <p class="text-muted">Aucun allergène renseigné pour ce menu.</p>
{% endif %}

<hr>

<h3>Plats du menu</h3>
<ul>
    {% for plat in menu.plats %}
        <li class="mb-3">
            <strong>{{ plat.nom }}</strong> ({{ plat.type }})
            <br>
            <small class="text-muted">{{ plat.description }}</small>
        </li>
    {% else %}
        <li class="text-muted">Aucun plat associé à ce menu.</li>
    {% endfor %}
</ul>

<hr>

{% if aDejaLaisseAvis %}
    <div class="alert alert-info mb-4">
        Vous avez déjà laissé un avis pour ce menu.
        <a href="{{ path('compte_avis_modifier', { id: avisExistant.id }) }}"
           class="btn btn-sm btn-warning ms-2">
            Modifier mon avis
        </a>
    </div>
{% endif %}

{% if peutLaisserAvis %}
    <a href="{{ path('compte_avis', { id: commandeEligible.id }) }}"
       class="btn btn-primary mb-4">
        Laisser un avis
    </a>
{% endif %}

<div class="mt-4">
    {% for a in avis %}
        <div class="avis-card">

            <div class="d-flex align-items-center gap-2 mb-2">
                <div class="avatar-default"></div>
                {% include 'components/stars.html.twig' with { note: a.note } %}
            </div>

            <p class="mt-2">{{ a.commentaire }}</p>
            <small class="text-muted">Le {{ a.date|date('d/m/Y') }}</small>

        </div>
    {% endfor %}
</div>

<a href="{{ path('app_commander') }}" class="btn btn-secondary mt-4">Retour</a>

{% endblock %}
