<div class="menus-grid">

    {% for menu in menus %}
        <div class="menu-card">

            {% if menu.images is not empty %}
                <img src="{{ asset('uploads/menus/' ~ menu.images[0]) }}" alt="{{ menu.titre }}">
            {% else %}
                <img src="{{ asset('uploads/menus/default.jpg') }}" alt="Image indisponible">
            {% endif %}

            <div class="menu-info">
                <h3>{{ menu.titre }}</h3>

                <p class="menu-description">
                    {{ menu.description|slice(0, 80) ~ '...' }}
                </p>

                <p class="menu-theme">
                    <strong>Thème :</strong> {{ menu.theme ? menu.theme.nom : 'Aucun' }}
                </p>

                <p class="menu-min">
                    Minimum : {{ menu.nbPersonnesMin }} personnes
                </p>

                <p class="menu-stock">
                    Stock : {{ menu.stockDisponible }}
                </p>

                {# --- AFFICHAGE PRIX CORRIGÉ --- #}
                {% set prixBase = menu.prixBase %}
                {% set min = menu.nbPersonnesMin %}
                {% set prixParPersonne = prixBase / min %}

                <p class="price">
                    <strong>{{ prixBase|number_format(2, ',', ' ') }} € TTC</strong><br>
                    <small>
                        soit {{ prixParPersonne|number_format(2, ',', ' ') }} € / personne  
                        (min. {{ min }} pers.)
                    </small>
                </p>

                <a href="{{ path('app_menu_show', {id: menu.id}) }}" class="btn-primary">
                    Voir détails
                </a>
            </div>

        </div>
    {% else %}
        <p class="text-muted">Aucun menu ne correspond à votre recherche.</p>
    {% endfor %}

</div>
