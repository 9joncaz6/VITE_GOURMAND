{% extends 'base.html.twig' %}

{% block title %}Menus{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/pages/menu.css') }}">
{% endblock %}

{% block body %}

<h1 class="page-title">Menus</h1>

<div class="filters">

    {# Bouton Tous #}
    <a href="{{ path('app_menu_index') }}"
       class="filter-btn {{ criteria.theme is empty and criteria.prixMin is empty and criteria.prixMax is empty ? 'active' : '' }}">
        Tous
    </a>

    {# Filtres par thème #}
    {% for t in themes %}
        <a href="{{ path('app_menu_index', { theme: t.nom }) }}"
           class="filter-btn {{ criteria.theme == t.nom ? 'active' : '' }}">
            {{ t.nom }}
        </a>
    {% endfor %}

    {# Filtres prix #}
    <a href="{{ path('app_menu_index', { prixMax: 15 }) }}"
       class="filter-btn {{ criteria.prixMax == 15 ? 'active' : '' }}">
        -15€
    </a>

    <a href="{{ path('app_menu_index', { prixMin: 15, prixMax: 25 }) }}"
       class="filter-btn {{ criteria.prixMin == 15 and criteria.prixMax == 25 ? 'active' : '' }}">
        15–25€
    </a>

    <a href="{{ path('app_menu_index', { prixMin: 25 }) }}"
       class="filter-btn {{ criteria.prixMin == 25 ? 'active' : '' }}">
        +25€
    </a>

</div>

<div id="menu-list">

    <div class="menus-grid">

        {% for menu in menus %}

            <div class="menu-card {% if menu.stockDisponible == 0 %}menu-out{% endif %}">

                {% set img = menu.image ?? 'default.jpg' %}

                <div class="menu-img-wrapper">
                    <img src="{{ asset('uploads/menus/' ~ img) }}" alt="{{ menu.titre }}">

                    {% if menu.stockDisponible == 0 %}
                        <span class="badge-out">Rupture de stock</span>
                    {% endif %}
                </div>

                <div class="menu-info">

                    <h3>{{ menu.titre }}</h3>

                    <p class="menu-description">
                        {{ menu.description|slice(0, 80) ~ '...' }}
                    </p>

                    <p class="menu-min">
                        Minimum : {{ menu.nbPersonnesMin }} personnes
                    </p>

                    <p class="menu-stock">
                        Stock : {{ menu.stockDisponible }}
                    </p>

                    <p class="price">
                        Prix TTC {{ menu.prixBase|number_format(2, '.', ' ') }}€
                    </p>

                    <a href="{{ path('app_menu_show', { id: menu.id }) }}"
                       class="btn-primary {% if menu.stockDisponible == 0 %}disabled{% endif %}">
                        Voir détails
                    </a>

                </div>

            </div>

        {% endfor %}

    </div>

</div>

<section class="menus-avis">
    <h2>Les avis de nos clients</h2>

    <div class="avis-grid">
        {% for avi in avis %}
            {% include 'components/avis_home_card.html.twig' with { avi: avi } %}
        {% endfor %}
    </div>
</section>

{% endblock %}
