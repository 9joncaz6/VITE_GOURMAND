{% extends 'base.html.twig' %}

{% block title %}Menus{% endblock %}

{% block body %}

<h1 class="mb-4">Liste des menus</h1>

{# Bouton créer un menu — réservé aux admins #}
{% if is_granted('ROLE_ADMIN') %}
    <a href="{{ path('app_menu_new') }}" class="btn btn-primary mb-3">
        Créer un menu
    </a>
{% endif %}

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Titre</th>
            <th>Prix de base</th>
            <th>Thème</th>
            <th>Régime</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>

    <tbody>
        {% for menu in menus %}
            <tr>
                <td>{{ menu.titre }}</td>
                <td>{{ menu.prixBase }} €</td>
                <td>{{ menu.theme ? menu.theme.nom : 'Aucun' }}</td>
                <td>{{ menu.regime ? menu.regime.nom : 'Aucun' }}</td>

                <td class="text-center">

                    {# Bouton Voir — visible pour tout le monde #}
                    <a href="{{ path('app_menu_show', {id: menu.id}) }}"
                       class="btn btn-info btn-sm me-1">
                        Voir
                    </a>

                    {# Boutons admin #}
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_menu_edit', {id: menu.id}) }}"
                           class="btn btn-warning btn-sm me-1">
                            Modifier
                        </a>

                        <form method="post"
                              action="{{ path('app_menu_delete', {id: menu.id}) }}"
                              style="display:inline-block;">
                            <input type="hidden" name="_token"
                                   value="{{ csrf_token('delete' ~ menu.id) }}">
                            <button class="btn btn-danger btn-sm"
                                    onclick="return confirm('Supprimer ce menu ?')">
                                Supprimer
                            </button>
                        </form>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5" class="text-center text-muted py-4">
                    Aucun menu disponible.
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>

{% endblock %}