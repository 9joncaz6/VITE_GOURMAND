{% extends 'base.html.twig' %}

{% block title %}Menus{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/pages/menu.css') }}">
{% endblock %}

{% block body %}

<h1 class="page-title">Menus</h1>

<!-- ============================
     FILTRES
============================ -->
<div class="filters">

    <a href="{{ path('app_menu_index') }}"
       class="filter-btn {{ criteria.theme is empty and criteria.regime is empty and criteria.prixMin is empty and criteria.prixMax is empty and criteria.nbPersonnesMin is empty ? 'active' : '' }}">
        Tous
    </a>

    <a href="{{ path('app_menu_index', { theme: 1 }) }}"
       class="filter-btn {{ criteria.theme == 1 ? 'active' : '' }}">
        Thème 1
    </a>

    <a href="{{ path('app_menu_index', { theme: 2 }) }}"
       class="filter-btn {{ criteria.theme == 2 ? 'active' : '' }}">
        Thème 2
    </a>

    <a href="{{ path('app_menu_index', { regime: 1 }) }}"
       class="filter-btn {{ criteria.regime == 1 ? 'active' : '' }}">
        Régime 1
    </a>

    <a href="{{ path('app_menu_index', { prixMin: 0, prixMax: 15 }) }}"
       class="filter-btn {{ criteria.prixMax == 15 ? 'active' : '' }}">
        -15€
    </a>

    <a href="{{ path('app_menu_index', { prixMin: 15, prixMax: 25 }) }}"
       class="filter-btn {{ criteria.prixMin == 15 and criteria.prixMax == 25 ? 'active' : '' }}">
        15–25€
    </a>

    <a href="{{ path('app_menu_index', { prixMin: 25 }) }}"
       class="filter-btn {{ criteria.prixMin == 25 ? 'active' : '' }}">
        +25€
    </a>

</div>

<!-- ============================
     LISTE DES MENUS
============================ -->
<div class="menus-grid">

    {% for menu in menus %}
        <div class="menu-card">

            <!-- Image -->
            {% if menu.images is not empty %}
                <img src="{{ asset('uploads/menus/' ~ menu.images[0]) }}" alt="{{ menu.titre }}">
            {% else %}
                <img src="{{ asset('uploads/menus/default.jpg') }}" alt="Image indisponible">
            {% endif %}

            <div class="menu-info">

                <h3>{{ menu.titre }}</h3>

                <p class="menu-description">
                    {{ menu.description|slice(0, 80) ~ '...' }}
                </p>

                <!-- Allergènes NoSQL -->
                {% set allergenes = allergeneService.getAllergenesForMenu(menu.id) %}
                {% if allergenes %}
                    <p class="small text-muted">
                        Allergènes : {{ allergenes|join(', ') }}
                    </p>
                {% endif %}

                <p class="menu-min">
                    Minimum : {{ menu.nbPersonnesMin }} personnes
                </p>

                <p class="menu-stock">
                    Stock : {{ menu.stockDisponible }}
                </p>

                <p class="price">
                    Prix TTC {{ menu.prixBase|number_format(2, '.', ' ') }}€
                </p>

                <a href="{{ path('app_menu_show', {id: menu.id}) }}" class="btn-primary">
                    Voir détails
                </a>

            </div>

        </div>
    {% else %}
        <p class="text-muted">Aucun menu ne correspond à votre recherche.</p>
    {% endfor %}

</div>

<!-- ===========================
     AVIS CLIENTS
============================ -->
<section class="menus-avis">
    <h2>Les avis de nos clients</h2>

    <div class="avis-grid">
        {% for avi in avis|slice(0, 3) %}
            {% include 'components/avis_home_card.html.twig' with { avi: avi } %}
        {% endfor %}
    </div>
</section>

{% endblock %}
