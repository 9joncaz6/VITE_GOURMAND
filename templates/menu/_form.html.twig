{# ===========================
   SCRIPT PREVIEW IMAGES
   =========================== #}

<script>
const input = document.getElementById('menu_images');
const preview = document.getElementById('preview');

// Fichiers sélectionnés
let filesArray = [];

// Formats autorisés
const allowedTypes = ['image/jpeg', 'image/png', 'image/webp'];

input.addEventListener('change', function (event) {
    preview.innerHTML = "";
    filesArray = [];

    const selectedFiles = Array.from(event.target.files);

    selectedFiles.forEach(file => {
        if (!allowedTypes.includes(file.type)) {
            alert("Format non autorisé : " + file.name + "\nFormats acceptés : JPG, PNG, WEBP");
            return;
        }
        filesArray.push(file);
    });

    updateInputFiles();
    displayPreviews();
});

function displayPreviews() {
    preview.innerHTML = "";

    filesArray.forEach((file, index) => {
        const reader = new FileReader();

        reader.onload = function(e) {
            const col = document.createElement('div');
            col.classList.add('col-3', 'mb-3', 'position-relative');

            const img = document.createElement('img');
            img.src = e.target.result;
            img.classList.add('img-fluid', 'rounded');

            const btn = document.createElement('button');
            btn.innerHTML = "✖";
            btn.classList.add('btn', 'btn-danger', 'btn-sm', 'position-absolute');
            btn.style.top = "5px";
            btn.style.right = "5px";

            btn.addEventListener('click', function () {
                filesArray.splice(index, 1);
                updateInputFiles();
                displayPreviews();
            });

            col.appendChild(img);
            col.appendChild(btn);
            preview.appendChild(col);
        };

        reader.readAsDataURL(file);
    });
}

function updateInputFiles() {
    const dataTransfer = new DataTransfer();
    filesArray.forEach(file => dataTransfer.items.add(file));
    input.files = dataTransfer.files;
}
</script>