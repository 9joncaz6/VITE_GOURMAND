{% extends 'base.html.twig' %}

{% block title %}Panier - V & G{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/pages/panier.css') }}">
{% endblock %}

{% block body %}

<div class="cart-container">

    <h1 class="cart-title">Votre panier</h1>

    {% if items is empty %}

        <p class="empty-cart">Votre panier est vide.</p>

    {% else %}

        <section class="cart-list">

            {% for item in items %}

                {% set img = item.menu.image 
                    ?? (item.menu.images[0] ?? 'default.jpg') 
                %}

                <div class="cart-item">

                    <img src="{{ asset('uploads/menus/' ~ img) }}"
                         alt="{{ item.menu.titre }}"
                         class="cart-img">

                    <div class="cart-info">
                        <h3>{{ item.menu.titre }}</h3>
                        <p class="price">{{ item.menu.prixBase }} €</p>

                        <div class="qty-controls">

                            {# BOUTON MOINS #}
                            <a href="{{ path('app_panier_update', {
                                menuId: item.menu.id,
                                quantite: item.quantite - 1
                            }) }}" class="qty-btn">−</a>

                            <span class="qty-value">{{ item.quantite }}</span>

                            {# BOUTON PLUS #}
                            <a href="{{ path('app_panier_update', {
                                menuId: item.menu.id,
                                quantite: item.quantite + 1
                            }) }}" class="qty-btn">+</a>

                        </div>

                        {% set prixBase = item.menu.prixBase + 0 %}
                        {% set nbMin = item.menu.nbPersonnesMin + 0 %}
                        {% set qte = item.quantite + 0 %}
                        {% set sousTotal = (prixBase / nbMin) * qte %}

                        <p class="subtotal">
                            Sous-total :
                            {{ sousTotal | number_format(2, ',', ' ') }} €
                        </p>
                    </div>

                    <a href="{{ path('app_panier_remove', {menuId: item.menu.id}) }}"
                       class="remove-btn">✕</a>

                </div>

            {% endfor %}

        </section>

        <section class="cart-total">
            <p>Total : <strong>{{ total | number_format(2, ',', ' ') }} €</strong></p>

            <a href="{{ path('app_commande_validation') }}" class="btn-primary">
                Valider la commande
            </a>
        </section>

    {% endif %}

</div>

{% endblock %}
